# ─── Server Configuration ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Connection ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance_dashboard?appName=Cluster0

# ─── JWT Configuration ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
